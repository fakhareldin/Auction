// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  EXPIRED
  REJECTED
}

enum ListingCondition {
  NEW
  USED_LIKE_NEW
  USED_GOOD
  USED_FAIR
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  WITHDRAWN
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  phoneNumber       String?   @unique
  phoneVerified     Boolean   @default(false)
  firstName         String
  lastName          String
  avatar            String?
  role              UserRole  @default(USER)
  city              String
  bio               String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?

  // Relations
  listings          Listing[]
  sentMessages      Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  favorites         Favorite[]
  refreshTokens     RefreshToken[]
  reports           Report[]
  sentOffers        Offer[]   @relation("BuyerOffers")
  receivedOffers    Offer[]   @relation("SellerOffers")

  @@index([email])
  @@index([phoneNumber])
  @@index([city])
}

model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Category {
  id          String     @id @default(uuid())
  nameAr      String
  nameEn      String
  slug        String     @unique
  icon        String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  listings    Listing[]
  order       Int        @default(0)
  isActive    Boolean    @default(true)

  @@index([parentId])
  @@index([slug])
}

model Listing {
  id              String           @id @default(uuid())
  title           String
  description     String           @db.Text
  price           Decimal          @db.Decimal(12, 2)
  negotiable      Boolean          @default(true)
  condition       ListingCondition
  status          ListingStatus    @default(ACTIVE)
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id])
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  city            String
  district        String?
  latitude        Float?
  longitude       Float?
  images          ListingImage[]
  viewCount       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  expiresAt       DateTime?
  isFeatured      Boolean          @default(false)
  featuredUntil   DateTime?

  // Relations
  favorites       Favorite[]
  reports         Report[]
  offers          Offer[]

  @@index([userId])
  @@index([categoryId])
  @@index([city])
  @@index([status])
  @@index([createdAt])
  @@index([price])
}

model ListingImage {
  id          String   @id @default(uuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url         String
  publicId    String   // Cloudinary public ID for deletion
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([listingId])
}

model Message {
  id            String   @id @default(uuid())
  senderId      String
  sender        User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId    String
  receiver      User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content       String   @db.Text
  isRead        Boolean  @default(false)
  readAt        DateTime?
  createdAt     DateTime @default(now())

  // For grouping messages into conversations
  conversationId String

  @@index([senderId])
  @@index([receiverId])
  @@index([conversationId])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model Report {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  details   String?  @db.Text
  status    String   @default("PENDING") // PENDING, REVIEWED, RESOLVED
  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([userId])
  @@index([status])
}

model Offer {
  id            String      @id @default(uuid())
  listingId     String
  listing       Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         User        @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User        @relation("SellerOffers", fields: [sellerId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(12, 2)
  message       String?     @db.Text
  status        OfferStatus @default(PENDING)
  sellerMessage String?     @db.Text
  counterAmount Decimal?    @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}
